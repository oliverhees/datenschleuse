# Datenschleuse — Umgebungsvariablen
# Kopiere diese Datei zu .env und trage deine Werte ein.
#
# Diese Datei deckt BEIDE Deploy-Wege ab:
#  - lokal:   `docker compose up --build`   (docker-compose.yml)
#  - Coolify: docker-compose.coolify.yml    (siehe docs/DEPLOY.md)
# In Coolify werden dieselben Variablen 1:1 als Environment-Variablen in der UI
# gesetzt. Die oeffentliche Domain vergibt Coolify automatisch (SERVICE_FQDN) --
# dafuer ist KEINE Variable noetig.
#
# Single-Tenant: EINE Instanz = EIN EUROUTER_API_KEY. Kein Multi-User-Sharing.

# --- Upstream (Pflicht) -----------------------------------------------------
# Dein eigener eurouter.ai API-Key (https://www.eurouter.ai?ref=06ZUHPBK).
EUROUTER_API_KEY=sk-dein-eurouter-key

# --- Zugriff auf die Datenschleuse (Pflicht) --------------------------------
# Master-Key, mit dem deine Tools die Datenschleuse ansprechen.
# MUSS mit "sk-" beginnen (LiteLLM-Vorgabe). Zufaelligen Teil erzeugen mit:
#   echo "sk-$(openssl rand -hex 32)"
DATENSCHLEUSE_MASTER_KEY=sk-datenschleuse-lokal

# --- QI-State-Verschluesselung (Pflicht, solange QI-Layer aktiv) ------------
# Fernet-Schluessel fuer den verschluesselten Quasi-Identifier-Session-State.
# PFLICHT, sobald der QI-Layer aktiv ist (qi_risk_preset in litellm/config.yaml
# gesetzt -- Default: aktiv). Der State laeuft nur verschluesselt (fail-closed).
# Erzeugen mit:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DATENSCHLEUSE_STATE_KEY=hier-einen-fernet-key-eintragen
# Optionale TTL des QI-Session-States in Sekunden (Default 24h = 86400).
# DATENSCHLEUSE_STATE_TTL_SECONDS=86400

# --- Admin-UI (Pflicht: Passwort) -------------------------------------------
# LiteLLM-Admin-UI unter /ui (Spend-Logs, Guardrail-Metadaten, NIE Message-Content).
# UI_PASSWORD hat KEINEN Default -- damit das Admin-UI nie mit bekanntem
# Passwort oeffentlich erreichbar startet. Starkes Passwort erzeugen:
#   openssl rand -hex 32
UI_USERNAME=admin
UI_PASSWORD=aendere-mich

# --- Interne Spend-Log-Datenbank --------------------------------------------
# Postgres treibt das Admin-UI + Spend-Logs an. Fuer einen oeffentlichen Deploy
# ein STARKES Passwort setzen (openssl rand -hex 32) -- die DB ist zwar nur
# intern erreichbar, aber "datenschleuse/datenschleuse" ist kein Passwort.
# Im Coolify-Compose ist DATENSCHLEUSE_DB_PASSWORD Pflicht (kein Default).
DATENSCHLEUSE_DB_USER=datenschleuse
DATENSCHLEUSE_DB_PASSWORD=aendere-mich-starkes-passwort
DATENSCHLEUSE_DB_NAME=datenschleuse
