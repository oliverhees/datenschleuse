# Datenschleuse — Umgebungsvariablen
# Kopiere diese Datei zu .env und trage deine Werte ein.

# Dein eurouter.ai API-Key (https://www.eurouter.ai)
EUROUTER_API_KEY=sk-dein-eurouter-key

# Master-Key, mit dem deine Tools die Datenschleuse ansprechen (frei waehlbar)
DATENSCHLEUSE_MASTER_KEY=sk-datenschleuse-lokal

# Postgres fuer das LiteLLM Admin-UI (Spend-Logs, NIE Message-Content).
# Defaults reichen fuer lokale Entwicklung, fuer echten Deploy aendern.
DATENSCHLEUSE_DB_USER=datenschleuse
DATENSCHLEUSE_DB_PASSWORD=datenschleuse
DATENSCHLEUSE_DB_NAME=datenschleuse

# Admin-UI-Login (http://localhost:4000/ui) -- PFLICHT, kein Default.
UI_USERNAME=admin
UI_PASSWORD=aendere-mich
